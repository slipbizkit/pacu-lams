DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
JWT_SECRET=replace-with-a-random-64-char-string

# Public origin of the frontend. Locks CORS in production and builds the links and
# logo images in outgoing emails, so it must be the URL staff and clients actually
# reach the app on. No trailing slash.
FRONTEND_URL=http://localhost:5173

NODE_ENV=development

RESEND_API_KEY=replace-with-your-resend-api-key

# Sender address for all outgoing email. If unset, falls back to Resend's sandbox
# sender (onboarding@resend.dev), which can only deliver to the address that owns
# the Resend account — every other recipient is rejected. For real delivery, verify
# a domain at resend.com/domains and use an address on that domain.
EMAIL_FROM=PACU Legal Assistance <no-reply@your-verified-domain.example>
